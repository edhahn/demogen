# demogen environment configuration
#
# Copy this file to `.env.demogen` (next to where you run `demogen`) and
# uncomment the variables you need. demogen loads `./.env.demogen` at startup
# automatically, or pass `--env <path>` to load a different file.
#
# Variables already set in your shell environment ALWAYS win — this file
# only fills in what's missing. Never commit a real `.env.demogen` to git.

# ---------------------------------------------------------------------------
# Recording target
# ---------------------------------------------------------------------------

# Base URL for the Playwright recorder (also overridden by --base-url).
# DEMOGEN_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Directory layout (defaults: ./demos/{interstitial,output} next to script)
# ---------------------------------------------------------------------------

# DEMOGEN_OUT_DIR=./demos
# DEMOGEN_INTERSTITIAL_DIR=./demos/interstitial
# DEMOGEN_OUTPUT_DIR=./demos/output

# Path to the friendly-name → voice-ID map (see examples/voices.yml).
# DEMOGEN_VOICES=./voices.yml

# ---------------------------------------------------------------------------
# TTS provider — pick exactly one of: say | elevenlabs | openai
# ---------------------------------------------------------------------------

# DEMOGEN_TTS_SERVICE=say

# --- ElevenLabs -------------------------------------------------------------
# DEMOGEN_TTS_SERVICE=elevenlabs
# ELEVENLABS_API_KEY=sk_...
# Fallback voice when no voices.yml entry matches the requested friendly name.
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- OpenAI -----------------------------------------------------------------
# DEMOGEN_TTS_SERVICE=openai
# OPENAI_API_KEY=sk-...
# Fallback voice — alloy | echo | fable | onyx | nova | shimmer
# OPENAI_VOICE=nova
# Model — tts-1 (faster, default) or tts-1-hd (higher fidelity)
# OPENAI_TTS_MODEL=tts-1
