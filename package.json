{
  "name": "@edhahn/demogen",
  "version": "0.1.0",
  "description": "Automated product demo recordings driven by a YAML script. Playwright + TTS narration + ffmpeg composition.",
  "license": "MIT",
  "author": "Edward Hahn",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "demogen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "demo",
    "recording",
    "playwright",
    "tts",
    "ffmpeg",
    "screencast",
    "narration"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@playwright/test": "^1.48.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edhahn/demogen.git"
  }
}
